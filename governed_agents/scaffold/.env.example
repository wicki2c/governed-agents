# Copy to .env.local and fill in. .env.local is gitignored.
# These are NAMES ONLY. Real values never live in this repo.
#
# The core framework needs none of these to run the orchestrator, the
# watchdog, or the zero-LLM demo. Set what your own agents and hooks need.

# ─── Orchestration server ──────────────────────────────────────────────────
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8005

# ─── Runtime agents (optional) ─────────────────────────────────────────────
# Only needed to run real `claude -p` agents via the orchestrator runner.
# The bundled demo and the test suite do NOT require this.
# ANTHROPIC_API_KEY=

# ─── Your own integrations (examples) ──────────────────────────────────────
# Add the secrets your decision hooks / agents need here. Keep them in
# .env.local only — never commit real values. For example:
# GITHUB_TOKEN=
# CLOUDFLARE_API_TOKEN=
